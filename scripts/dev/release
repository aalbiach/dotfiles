#!/usr/bin/env bash

# Exit on error, undefined variables, and pipe failures
set -euo pipefail

source "$DOTLY_PATH/scripts/core/_main.sh"

##? Release the Maven project
#?? 1.0.0
##?
##? Usage:
##?    release

docs::parse "$@"

# Colors for output (readonly)
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly NC='\033[0m' # No Color

# Base branch to release from
readonly BASE_BRANCH="dev"

# Function to print colored messages
print_info() {
    echo -e "${GREEN}${1}${NC}"
}

print_error() {
    echo -e "${RED}${1}${NC}" >&2
}

print_warning() {
    echo -e "${YELLOW}${1}${NC}" >&2
}

print_question() {
    echo -e "${BLUE}${1}${NC}"
}

# Cleanup function
cleanup() {
    local exit_code=$?
    if [[ ${exit_code} -ne 0 ]]; then
        print_error "Script failed with exit code ${exit_code}"
    fi
}

trap cleanup EXIT

# Detect available Maven command
detect_maven_command() {
    local -a maven_commands=("./mvnw" "mvnw" "mvnd" "mvn")
    local maven_options="--raw-streams"
    for cmd in "${maven_commands[@]}"; do
        if command -v "${cmd}" &>/dev/null; then
            echo "${cmd} ${maven_options}"
            return 0
        fi
    done
    print_error "No Maven command found. Please install Maven or ensure mvnw is available."
    return 1
}

# Maven command to use (will be set in main)
MAVEN_CMD=""

# Set MAVEN_OPTS to suppress Java warnings about illegal reflective access (JDK 24+ only)
JAVA_MAJOR_VERSION=$(java -version 2>&1 | awk -F '"' '/version/ {print $2}' | awk -F '.' '{print ($1 == "1" ? $2 : $1)}')
if [[ "${JAVA_MAJOR_VERSION}" -ge 24 ]]; then
    export MAVEN_OPTS="--sun-misc-unsafe-memory-access=allow"
fi


# Function to get current version from pom.xml
get_current_version() {
    local version
    version=$(${MAVEN_CMD} help:evaluate -Dexpression=project.version -DforceStdout --quiet)
    if [[ -z "${version}" ]]; then
        print_error "Failed to retrieve version from pom.xml"
        return 1
    fi
    echo "${version}"
}

# Function to set version in pom.xml
set_version() {
    local new_version="${1}"
    if [[ -z "${new_version}" ]]; then
        print_error "Version parameter is required"
        return 1
    fi
    ${MAVEN_CMD} versions:set -DnewVersion="${new_version}" -DgenerateBackupPoms=false --quiet
}

# Function to remove -SNAPSHOT suffix
remove_snapshot() {
    local version="${1}"
    echo "${version%-SNAPSHOT}"
}

# Generic function to bump version
# Parameters: version, bump_type (major|minor|patch)
bump_version() {
    local version="${1}"
    local bump_type="${2}"

    if [[ ! "${version}" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        print_error "Invalid version format: ${version}"
        return 1
    fi

    local IFS='.'
    local -a VERSION_PARTS
    read -ra VERSION_PARTS <<< "${version}"

    local major="${VERSION_PARTS[0]}"
    local minor="${VERSION_PARTS[1]}"
    local patch="${VERSION_PARTS[2]}"

    case "${bump_type}" in
        major)
            major=$((major + 1))
            minor=0
            patch=0
            ;;
        minor)
            minor=$((minor + 1))
            patch=0
            ;;
        patch)
            patch=$((patch + 1))
            ;;
        *)
            print_error "Invalid bump type: ${bump_type}"
            return 1
            ;;
    esac

    echo "${major}.${minor}.${patch}"
}

# Convenience wrapper functions
bump_major() {
    bump_version "${1}" "major"
}

bump_minor() {
    bump_version "${1}" "minor"
}

bump_patch() {
    bump_version "${1}" "patch"
}

# Validate that current version is a SNAPSHOT
validate_snapshot_version() {
    local version="${1}"
    if [[ ! "${version}" =~ -SNAPSHOT$ ]]; then
        print_error "Current version is not a SNAPSHOT version. Cannot proceed."
        exit 1
    fi
}

# Calculate version options from current version
calculate_version_options() {
    local current_version="${1}"
    local base_version
    base_version=$(remove_snapshot "${current_version}")

    echo "${base_version}"
    bump_major "${base_version}"
    bump_minor "${base_version}"
    bump_patch "${base_version}"
}

# Confirm action with user
confirm_action() {
    local message="${1}"
    local confirm

    echo ""
    read -r -p "$(echo -e "${BLUE}[?]${NC} ${message} (Y/n): ")" confirm
    # Default to 'Y' if empty
    confirm="${confirm:-Y}"
    if [[ ! "${confirm}" =~ ^[Yy]$ ]]; then
        print_warning "Operation cancelled by user."
        exit 0
    fi
}

# Create and checkout a release branch from 'dev'
create_release_branch() {
    local branch_name="${1}"

    print_info "Creating branch ${branch_name}..."
    if ! git checkout -b "${branch_name}"; then
        print_error "Failed to create branch ${branch_name}"
        exit 1
    fi
    print_info "✓ Switched to branch ${branch_name}"
}

# Get the name of the current git branch
get_current_branch() {
    git rev-parse --abbrev-ref HEAD
}

# Commit and push changes to the current branch
commit_and_push_changes() {
    local commit_message="${1}"
    local current_branch
    current_branch=$(get_current_branch)

    print_info "Committing changes..."
    git add pom.xml

    if ! git commit -m "${commit_message}"; then
        print_error "Failed to commit changes"
        exit 1
    fi
    print_info "✓ Changes committed"

    print_info "Pushing changes to origin/${current_branch}..."
    if ! git push origin "${current_branch}"; then
        print_error "Failed to push changes to origin/${current_branch}"
        exit 1
    fi
    print_info "✓ Changes pushed to origin/${current_branch}"
}

# Check for required commands
check_requirements() {
    # Check for git
    if ! command -v "git" &>/dev/null; then
        print_error "Required command 'git' not found"
        exit 1
    fi

    # Detect and set Maven command
    MAVEN_CMD=$(detect_maven_command)
    if [[ -z "${MAVEN_CMD}" ]]; then
        exit 1
    fi
    print_info "Using Maven command: ${MAVEN_CMD}"
}

# Main script starts here
main() {
  check_requirements

  print_info "Starting release process..."

  # Check git status
  print_info "Checking git workspace status..."
  local git_status
  git_status=$(git status --porcelain)
  if [[ -n "${git_status}" ]]; then
      print_error "Git workspace is not clean. Please commit or stash your changes before releasing."
      git status --short
      exit 1
  fi

  # Choose workflow type
  print_info "Choosing workflow type..."
  echo ""
  print_question "What would you like to do?"
  echo "  1) Create a release (remove -SNAPSHOT, commit, and push)"
  echo "  2) Create a pre-release (bump version to next -SNAPSHOT)"
  echo ""

  local workflow_choice
  while true; do
      read -r -p "Enter your choice (1-2): " workflow_choice
      case "${workflow_choice}" in
          1)
              print_info "Selected: Release workflow"

              # Switch to '${BASE_BRANCH}' and pull latest before releasing
              print_info "Switching to '${BASE_BRANCH}' branch..."
              if ! git checkout "${BASE_BRANCH}"; then
                  print_error "Failed to switch to '${BASE_BRANCH}' branch"
                  exit 1
              fi

              print_info "Updating '${BASE_BRANCH}' branch..."
              if ! git pull origin "${BASE_BRANCH}"; then
                  print_error "Failed to update '${BASE_BRANCH}' branch"
                  exit 1
              fi

              execute_release_workflow
              break
              ;;
          2)
              print_info "Selected: Pre-release workflow"
              execute_prerelease_workflow
              break
              ;;
          *)
              print_error "Invalid choice. Please enter 1 or 2."
              ;;
      esac
  done
}

# Execute release workflow
execute_release_workflow() {
  print_info "Starting release workflow..."

  local CURRENT_VERSION
  CURRENT_VERSION=$(get_current_version)
  print_info "Current version: ${CURRENT_VERSION}"

  validate_snapshot_version "${CURRENT_VERSION}"

  local -a version_options
  readarray -t version_options < <(calculate_version_options "${CURRENT_VERSION}")
  local BASE_VERSION="${version_options[0]}"
  local MAJOR_VERSION="${version_options[1]}"
  local MINOR_VERSION="${version_options[2]}"
  local PATCH_VERSION="${version_options[3]}"

  echo ""
  print_question "Which version would you like to release?"
  echo "  1) Current version (remove -SNAPSHOT): ${BASE_VERSION}"
  echo "  2) Major version: ${MAJOR_VERSION}"
  echo "  3) Minor version: ${MINOR_VERSION}"
  echo "  4) Patch version: ${PATCH_VERSION}"
  echo ""

  local RELEASE_VERSION
  while true; do
      local choice
      read -r -p "Enter your choice (1-4): " choice
      case "${choice}" in
          1) RELEASE_VERSION="${BASE_VERSION}"; break ;;
          2) RELEASE_VERSION="${MAJOR_VERSION}"; break ;;
          3) RELEASE_VERSION="${MINOR_VERSION}"; break ;;
          4) RELEASE_VERSION="${PATCH_VERSION}"; break ;;
          *) print_error "Invalid choice. Please enter 1, 2, 3, or 4." ;;
      esac
  done

  print_info "Selected release version: ${RELEASE_VERSION}"
  confirm_action "Proceed with release version ${RELEASE_VERSION}?"

  local RELEASE_BRANCH="release/v${RELEASE_VERSION}"
  if git show-ref --verify --quiet "refs/heads/${RELEASE_BRANCH}"; then
    print_warning "Branch ${RELEASE_BRANCH} already exists."
    confirm_action "Reuse existing branch ${RELEASE_BRANCH}?"
    print_info "Switching to existing branch ${RELEASE_BRANCH}..."
    if ! git checkout "${RELEASE_BRANCH}"; then
      print_error "Failed to switch to branch ${RELEASE_BRANCH}"
      exit 1
    fi
    print_info "✓ Switched to branch ${RELEASE_BRANCH}"
  else
    create_release_branch "${RELEASE_BRANCH}"
  fi

  set_version "${RELEASE_VERSION}"
  print_info "✓ Version set to ${RELEASE_VERSION}"

  commit_and_push_changes "chore: release version ${RELEASE_VERSION}"

  # Summary
  print_info ""
  print_info "=========================================="
  print_info "Release completed successfully!"
  print_info "=========================================="
  print_info "Released version: ${RELEASE_VERSION}"
  print_info "Changes pushed to: origin/${RELEASE_BRANCH}"
  print_info "=========================================="
}

# Execute pre-release workflow
execute_prerelease_workflow() {
  print_info "Starting pre-release workflow..."

  local CURRENT_BRANCH
  CURRENT_BRANCH=$(get_current_branch)

  local RELEASE_BRANCH
  if [[ "${CURRENT_BRANCH}" =~ ^release/ ]]; then
    RELEASE_BRANCH="${CURRENT_BRANCH}"
  else
    local -a release_branches
    readarray -t release_branches < <(git branch --list "release/*" | sed 's/^[* ]*//' | sort -V)

    if [[ ${#release_branches[@]} -eq 0 ]]; then
      local current_version
      current_version=$(get_current_version)
      local base_version
      base_version=$(remove_snapshot "${current_version}")
      RELEASE_BRANCH="release/v${base_version}"
      print_warning "No local release branches found."
      confirm_action "Create and switch to new branch ${RELEASE_BRANCH}?"
      print_info "Creating branch ${RELEASE_BRANCH}..."
      if ! git checkout -b "${RELEASE_BRANCH}"; then
        print_error "Failed to create branch ${RELEASE_BRANCH}"
        exit 1
      fi
      print_info "✓ Switched to branch ${RELEASE_BRANCH}"
    elif [[ ${#release_branches[@]} -eq 1 ]]; then
      RELEASE_BRANCH="${release_branches[0]}"
      print_info "Found release branch: ${RELEASE_BRANCH}"
      confirm_action "Switch to branch ${RELEASE_BRANCH} and proceed with pre-release?"
    else
      echo ""
      print_question "Multiple release branches found. Which one would you like to use?"
      local i=1
      for branch in "${release_branches[@]}"; do
        echo "  ${i}) ${branch}"
        i=$((i + 1))
      done
      echo ""
      local branch_choice
      while true; do
        read -r -p "Enter your choice (1-${#release_branches[@]}): " branch_choice
        if [[ "${branch_choice}" =~ ^[0-9]+$ ]] && \
           [[ "${branch_choice}" -ge 1 ]] && \
           [[ "${branch_choice}" -le ${#release_branches[@]} ]]; then
          RELEASE_BRANCH="${release_branches[$((branch_choice - 1))]}"
          break
        fi
        print_error "Invalid choice. Please enter a number between 1 and ${#release_branches[@]}."
      done
    fi

    print_info "Switching to branch ${RELEASE_BRANCH}..."
    if ! git checkout "${RELEASE_BRANCH}"; then
      print_error "Failed to switch to branch ${RELEASE_BRANCH}"
      exit 1
    fi
    print_info "✓ Switched to branch ${RELEASE_BRANCH}"
  fi

  local CURRENT_VERSION
  CURRENT_VERSION=$(get_current_version)
  print_info "Current version: ${CURRENT_VERSION}"

  # Remove -SNAPSHOT if present to get base version
  local BASE_VERSION
  if [[ "${CURRENT_VERSION}" =~ -SNAPSHOT$ ]]; then
    BASE_VERSION=$(remove_snapshot "${CURRENT_VERSION}")
  else
    BASE_VERSION="${CURRENT_VERSION}"
  fi

  local -a version_options
  readarray -t version_options < <(calculate_version_options "${BASE_VERSION}")
  local MAJOR_VERSION="${version_options[1]}"
  local MINOR_VERSION="${version_options[2]}"
  local PATCH_VERSION="${version_options[3]}"

  echo ""
  print_question "Which version would you like for the next pre-release?"
  echo "  1) Patch version: ${PATCH_VERSION}-SNAPSHOT"
  echo "  2) Minor version: ${MINOR_VERSION}-SNAPSHOT"
  echo "  3) Major version: ${MAJOR_VERSION}-SNAPSHOT"
  echo ""

  local NEXT_VERSION
  while true; do
      local choice
      read -r -p "Enter your choice (1-3): " choice
      case "${choice}" in
          1) NEXT_VERSION="${PATCH_VERSION}"; break ;;
          2) NEXT_VERSION="${MINOR_VERSION}"; break ;;
          3) NEXT_VERSION="${MAJOR_VERSION}"; break ;;
          *) print_error "Invalid choice. Please enter 1, 2, or 3." ;;
      esac
  done

  local NEXT_SNAPSHOT_VERSION="${NEXT_VERSION}-SNAPSHOT"
  print_info "Selected pre-release version: ${NEXT_SNAPSHOT_VERSION}"

  confirm_action "Proceed with pre-release version ${NEXT_SNAPSHOT_VERSION}?"

  print_info "Setting version to ${NEXT_SNAPSHOT_VERSION}..."
  set_version "${NEXT_SNAPSHOT_VERSION}"
  print_info "✓ Version set to ${NEXT_SNAPSHOT_VERSION}"

  commit_and_push_changes "chore: pre-release version ${NEXT_SNAPSHOT_VERSION}"

  # Summary
  print_info ""
  print_info "=========================================="
  print_info "Pre-release completed successfully!"
  print_info "=========================================="
  print_info "Pre-release version: ${NEXT_SNAPSHOT_VERSION}"
  print_info "Changes pushed to:   origin/${RELEASE_BRANCH}"
  print_info "=========================================="
}

# Execute main function
main
